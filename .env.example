# Platform Configuration Defaults
PLATFORM_NAME=grabber-platform
PLATFORM_NAMESPACE=robot-platform
MONITORING_NAMESPACE=monitoring
INGRESS_NAMESPACE=ingress-nginx
CLOUDFLARE_NAMESPACE=cloudflare
PLATFORM_ROOT=/opt/grabber-platform

# Kubernetes Image Settings
IMAGE_REGISTRY=ghcr.io
IMAGE_PULL_POLICY=IfNotPresent

# Kubernetes and Terraform Settings
KUBECONFIG_PATH=$HOME/.kube/config
TERRAFORM_ENVIRONMENT=local-vm
