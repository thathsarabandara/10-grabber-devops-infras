# Environment Variables Configuration
# Copy this file to .env and configure appropriately

# Application
NODE_ENV=production
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=24h

# MySQL Database Host
DB_HOST=db
DB_USER=thathsara
DB_PASSWORD=BandaPutha
MYSQL_ROOT_PASSWORD=BandaPuthaRoot

# Database Names
DB_NAME_GATEWAY=grabber_gateway
DB_NAME_AUTH=grabber_auth
DB_NAME_ROBOT=grabber_robot
DB_NAME_TELEMETRY=grabber_telemetry
DB_NAME_AI=grabber_ai

# Auth Service JWT Settings
SECRET_KEY=your_super_secret_jwt_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=300
REFRESH_TOKEN_EXPIRE_DAYS=30

# SMTP EMAIL (used by Auth Service)
MAIL_USERNAME="your-email@example.com"
MAIL_PASSWORD="your-app-password"
MAIL_FROM="your-email@example.com"
MAIL_PORT=587
MAIL_SERVER="smtp.gmail.com"
MAIL_FROM_NAME="Grabber"
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
USE_CREDENTIALS=True
VALIDATE_CERTS=True

# Redis Configuration (used by API Gateway)
REDIS_HOST=redis
REDIS_PORT=6379

# Python Services Database URLs
GATEWAY_DATABASE_URL=mysql+pymysql://
AUTH_DATABASE_URL=mysql+pymysql://thathsara:BandaPutha@db/grabber_auth
ROBOT_DATABASE_URL=mysql+pymysql://thathsara:BandaPutha@db/grabber_robot
TELEMETRY_DATABASE_URL=mysql+pymysql://thathsara:BandaPutha@db/grabber_telemetry
AI_DATABASE_URL=mysql+pymysql://thathsara:BandaPutha@db/grabber_ai

# MQTT Configuration
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=thathsara
MQTT_PASSWORD=BandaPutha

# AI Service Settings
CHROMA_DB_DIR=/data/vectordb/faces
GESTURE_DB_DIR=/data/vectordb/gestures
UPLOAD_DIR=/data/uploads/operators
WHISPER_MODEL=base
MEDIAPIPE_DETECTION_CONFIDENCE=0.7
MEDIAPIPE_TRACKING_CONFIDENCE=0.6
