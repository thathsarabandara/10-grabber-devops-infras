PLATFORM_NAMESPACE=robot-platform

FRONTEND_IMAGE=ghcr.io/username/grabber-frontend
GATEWAY_IMAGE=ghcr.io/username/grabber-api-gateway
AUTH_IMAGE=ghcr.io/username/grabber-auth-service
ROBOT_IMAGE=ghcr.io/username/grabber-robot-service
TELEMETRY_IMAGE=ghcr.io/username/grabber-telemetry-service
AI_IMAGE=ghcr.io/username/grabber-ai-service

FRONTEND_TAG=latest
GATEWAY_TAG=latest
AUTH_TAG=latest
ROBOT_TAG=latest
TELEMETRY_TAG=latest
AI_TAG=latest

FRONTEND_REPLICAS=1
GATEWAY_REPLICAS=1
AUTH_REPLICAS=1
ROBOT_REPLICAS=1
TELEMETRY_REPLICAS=1
AI_REPLICAS=1

FRONTEND_PORT=80
GATEWAY_PORT=8000
AUTH_PORT=8000
ROBOT_PORT=8000
TELEMETRY_PORT=8000
AI_PORT=8000

MYSQL_PORT=3306
REDIS_PORT=6379
MQTT_PORT=1883
MQTT_WEBSOCKET_PORT=9001

MYSQL_AUTH_DATABASE=auth_db
MYSQL_ROBOT_DATABASE=robot_db
MYSQL_TELEMETRY_DATABASE=telemetry_db
MYSQL_AI_DATABASE=ai_db

MYSQL_STORAGE_SIZE=10Gi
REDIS_STORAGE_SIZE=2Gi
MQTT_STORAGE_SIZE=2Gi
AI_MODEL_STORAGE_SIZE=5Gi
BACKUP_STORAGE_SIZE=10Gi
PROMETHEUS_STORAGE_SIZE=10Gi
GRAFANA_STORAGE_SIZE=2Gi
